---
/**
 * GA4 + Microsoft Clarity, ambos corriendo en un web worker vía Partytown
 * para no ocupar el main thread. Solo se emiten en producción y si el ID
 * correspondiente existe — sin IDs configurados este componente no
 * renderiza nada.
 */
const GA4_ID = import.meta.env.PUBLIC_GA4_ID as string | undefined;
const CLARITY_ID = import.meta.env.PUBLIC_CLARITY_ID as string | undefined;
const enabled = import.meta.env.PROD;

const ga4Init =
  GA4_ID &&
  `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${GA4_ID}');`;

const clarityInit =
  CLARITY_ID &&
  `(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","${CLARITY_ID}");`;
---

{
  enabled && GA4_ID && (
    <>
      <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`} />
      <script type="text/partytown" set:html={ga4Init} />
    </>
  )
}
{enabled && CLARITY_ID && <script type="text/partytown" set:html={clarityInit} />}
