---
/**
 * Coming Soon — a partir de «Iterra Coming Soon.dc.html» (Claude Design).
 * Un revelado radial sigue al puntero sobre la foto de follaje y descubre
 * las palabras de marca sobre el sello (Sol) como watermark central, que
 * rota lentísimo — la única decoración en movimiento que permite el DS.
 * Interacción en vanilla TS + GSAP (ver <script> al final).
 */
import { getImage } from 'astro:assets';

import logoUrl from '../assets/brand/logo-color.svg?url';
import solUrl from '../assets/brand/shapes/sol.svg?url';
import foliageImg from '../assets/images/foliage.jpg';
import Base from '../layouts/Base.astro';

const foliage = await getImage({ src: foliageImg, format: 'webp', width: 1920, quality: 75 });

// Los data URIs de Vite llevan comillas simples adentro: url() debe ir quoteado
const shapeVars = [`--ph:url("${foliage.src}")`, `--shape-sol:url("${solUrl}")`].join(';');
---

<Base title="Sitio en construcción">
  <link slot="head" rel="preload" as="image" href={foliage.src} />

  <main class="stage" id="stage" style={shapeVars} aria-label="Iterra — sitio en construcción">
    <h1 class="sr-only">Iterra — Sitio en construcción</h1>

    <div class="lay ph dim" aria-hidden="true"></div>
    <div class="lay tint" aria-hidden="true"></div>
    <div class="lay ph rev soft" aria-hidden="true"></div>
    <div class="lay glow" aria-hidden="true"></div>

    <div class="lay rev">
      <div class="seal" aria-hidden="true"></div>
      <span class="wrd wbig pw1">Iterar: la práctica que nos acerca.</span>
      <span class="wrd vert vl">Antes de proponer, escuchamos</span>
      <span class="wrd vert vr">Antes de actuar, entendemos</span>
      <span class="wrd wbig pw2">Hacer historia.</span>
    </div>

    <div class="ctr">
      <span class="ovl">Sitio en construcción</span>
      <img class="brandlogo" src={logoUrl} alt="Iterra" width="276" height="113" />
      <span class="soon">Muy pronto</span>
    </div>
  </main>
</Base>

<style is:global>
  body {
    overflow: hidden;
  }
</style>

<style>
  .stage {
    position: fixed;
    inset: 0;
    border: 12px solid var(--iterra-cream);
    background: var(--iterra-ink);
    overflow: hidden;
    cursor: crosshair;
    --mx: 50%;
    --my: 42%;
    --r: 260px;
  }

  .lay {
    position: absolute;
    inset: 0;
  }
  .ph {
    background-image: var(--ph);
    background-size: cover;
    background-position: center 30%;
  }
  .dim {
    filter: brightness(0.42) saturate(0.8);
  }
  .tint {
    background: color-mix(in srgb, var(--iterra-ink) 38%, transparent);
  }
  .rev {
    -webkit-mask-image: radial-gradient(
      circle var(--r) at var(--mx) var(--my),
      #000 0%,
      #000 45%,
      transparent 98%
    );
    mask-image: radial-gradient(
      circle var(--r) at var(--mx) var(--my),
      #000 0%,
      #000 45%,
      transparent 98%
    );
  }
  .soft {
    opacity: 0.45;
  }
  .glow {
    background: radial-gradient(
      circle calc(var(--r) * 1.35) at var(--mx) var(--my),
      color-mix(in srgb, var(--iterra-cream) 16%, transparent),
      color-mix(in srgb, var(--iterra-lime) 6%, transparent) 42%,
      transparent 72%
    );
    mix-blend-mode: screen;
    pointer-events: none;
  }

  /* El sello (Sol) como watermark central: grande, singular y en rotación
     lentísima — la única decoración en movimiento que permite el DS */
  .seal {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(88vmin, 760px);
    height: min(88vmin, 760px);
    background: var(--iterra-lime);
    opacity: 0.1;
    pointer-events: none;
    -webkit-mask-image: var(--shape-sol);
    mask-image: var(--shape-sol);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    animation: seal-spin 18s linear infinite;
  }
  @keyframes seal-spin {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }

  .wrd {
    font-family: var(--font-mono);
    color: var(--iterra-cream);
    letter-spacing: var(--ls-caps);
    text-transform: uppercase;
    font-size: 15px;
    white-space: nowrap;
  }
  .vert {
    writing-mode: vertical-rl;
    position: absolute;
  }
  .vl {
    left: clamp(16px, 3vw, 48px);
    top: 66%;
    transform: translateY(-50%);
  }
  .vr {
    right: clamp(16px, 3vw, 48px);
    top: 32%;
    transform: translateY(-50%);
  }
  .pw1 {
    position: absolute;
    left: clamp(28px, 5vw, 72px);
    top: clamp(28px, 7vh, 64px);
    text-align: left;
    max-width: min(300px, 26vw);
  }
  .pw2 {
    position: absolute;
    right: clamp(28px, 5vw, 80px);
    bottom: 14%;
    text-align: right;
  }
  .wbig {
    font-family: var(--font-display);
    text-transform: none;
    letter-spacing: -0.02em;
    font-size: clamp(20px, min(3vw, 4.2vh), 40px);
    font-weight: var(--fw-semibold);
    color: var(--iterra-lime);
    white-space: normal;
    max-width: min(340px, 32vw);
    line-height: 1.12;
    text-wrap: balance;
    text-align: right;
  }
  .pw1.wbig {
    text-align: left;
  }

  .ctr {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 28px;
    pointer-events: none;
    padding: 0 24px;
  }
  .ovl {
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--iterra-cream) 85%, transparent);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-size: 14px;
  }
  .brandlogo {
    width: clamp(320px, 44vw, 620px);
    height: auto;
    filter: drop-shadow(0 8px 32px color-mix(in srgb, var(--iterra-ink) 40%, transparent));
  }
  .soon {
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--iterra-cream) 60%, transparent);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-size: 13px;
    margin-top: 14px;
  }

  @media (max-height: 620px) {
    .wrd {
      font-size: 12px;
    }
    .wbig {
      font-size: clamp(18px, 4.2vh, 28px);
      max-width: 46vw;
    }
  }
  @media (max-width: 720px) {
    .vl,
    .vr {
      display: none;
    }
    .wrd {
      font-size: 12px;
    }
    .pw1 {
      top: 11%;
      max-width: 70vw;
    }
    .pw2 {
      bottom: 15%;
    }
    .wbig {
      max-width: 80vw;
      font-size: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stage {
      cursor: default;
    }
    .seal {
      animation: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const stage = document.getElementById('stage');

  // Revelado que sigue al puntero, con deriva Lissajous cuando no hay
  // input por 2.5s (cubre touch y el primer paint sin mouse).
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (stage && !reduced) {
    const setX = gsap.quickSetter(stage, '--mx');
    const setY = gsap.quickSetter(stage, '--my');
    const cur = { x: 0.5, y: 0.42 };
    const tgt = { x: 0.5, y: 0.42 };
    let lastInput = 0;
    const t0 = performance.now();

    gsap.ticker.add(() => {
      const now = performance.now();
      if (now - lastInput > 2500) {
        const t = (now - t0) / 1000;
        tgt.x = 0.5 + 0.33 * Math.sin(t * 0.35);
        tgt.y = 0.45 + 0.28 * Math.sin(t * 0.23 + 1.3);
      }
      cur.x += (tgt.x - cur.x) * 0.07;
      cur.y += (tgt.y - cur.y) * 0.07;
      setX(`${(cur.x * 100).toFixed(2)}%`);
      setY(`${(cur.y * 100).toFixed(2)}%`);
    });

    stage.addEventListener('pointermove', (e) => {
      const r = stage.getBoundingClientRect();
      tgt.x = (e.clientX - r.left) / r.width;
      tgt.y = (e.clientY - r.top) / r.height;
      lastInput = performance.now();
    });
  }
</script>
